    <!-- About Screen -->
    <string name="about_llm_hub">关于 LLM Hub</string>
    <string name="about_description">LLM Hub 是一个开源的安卓应用程序，它将大型语言模型的强大功能直接带到您的设备上。使用最先进的模型如 Gemma、Llama 和 Phi 进行 AI 对话。所有这些模型都在您的设备上本地运行，以实现最大的隐私保护和离线可访问性。</string>
    <string name="key_features">主要功能</string>
    <string name="feature_multiple_models">🤖 有多种 LLM 模型: Gemma-3, Llama-3.2, Phi-4, and Gemma-3n</string>
    <string name="feature_on_device">📱 设备端侧处理: 完全隐私，无需互联网</string>
    <string name="feature_vision_support">🖼️ 视觉模型支持: 多模态模型，能够理解图像</string>
    <string name="feature_gpu_acceleration">⚡ GPU 加速: 在支持的设备上优化性能</string>
    <string name="feature_offline_usage">💾 离线使用: 无需互联网连接即可聊天</string>
    <string name="feature_privacy_first">🔒 隐私优先: 您的对话永远不会离开您的设备</string>
    <string name="feature_modern_ui">🎨 现代界面: 简洁、直观的 Material Design 界面</string>
    <string name="developer_info">开发者信息</string>
    <string name="about_developer_info">这个项目由一个对让 AI 技术更易于访问充满热情的爱好者开发。我们欢迎您的反馈和贡献！</string>
    <string name="tech_stack">技术结构</string>
    <string name="about_tech_stack">LLM Hub 由现代的安卓技术构建: Kotlin, Jetpack Compose, Material Design 3, 以及 llama.cpp 库，用于高效的设备端推理</string>
    <string name="tech_kotlin_compose">🏗️ 使用 Kotlin &amp; Jetpack Compose 构建</string>
    <string name="tech_mediapipe_litert">🧠 由 MediaPipe &amp; LiteRT 驱动</string>
    <string name="tech_quantization">🚀 使用 INT4/INT8 量化优化</string>
    <string name="tech_gpu_acceleration">⚡ 通过 LiteRT XNNPACK 实现 GPU 加速</string>
    <string name="tech_models_source">🔗 模型来源于 HuggingFace &amp; Google</string>
