// LLMHub Secrets — RELEASE configuration
// !! DO NOT COMMIT THIS FILE !!
// Copy this file to Secrets.release.xcconfig and fill in your REAL AdMob IDs.
// The .gitignore already excludes Secrets.*.xcconfig

// AdMob App ID (tilde format, used in Info.plist via $(ADMOB_APP_ID))
ADMOB_APP_ID = ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

// Ad unit IDs (get from AdMob console)
ADMOB_BANNER_ID = ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_INTERSTITIAL_ID = ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

// Must be NO in release builds
ADMOB_USE_TEST_IDS = NO

// Must be NO in release builds
BYPASS_PREMIUM_UNLOCK = NO
