"terms_of_service" = "Hizmet Şartları";
"tos_last_updated" = "Son güncelleme: 16 Temmuz 2025";
"tos_welcome_text" = "LLM Hub\'a hoş geldiniz. Uygulamamızı kullanarak, bu Hizmet Şartlarına bağlı kalmayı kabul etmiş olursunuz. Lütfen bunları dikkatlice okuyun.";
"tos_welcome" = "LLM Hub\'a hoş geldiniz. Uygulamamızı kullanarak, bu Hizmet Şartlarına bağlı kalmayı kabul etmiş olursunuz. Lütfen bunları dikkatlice okuyun.";
"tos_acceptance_title" = "1. Şartların Kabulü";
"tos_acceptance_text" = "LLM Hub\'ı indirerek, yükleyerek veya kullanarak, bu Hizmet Şartlarını okuduğunuzu, anladığınızı ve bunlara bağlı kalmayı kabul ettiğinizi onaylarsınız. Bu şartları kabul etmiyorsanız, lütfen uygulamayı kullanmayın.";
"tos_app_description_title" = "2. Uygulama Açıklaması";
"tos_app_description_text" = "LLM Hub, cihaz üzerinde yapay zeka konuşmaları için Büyük Dil Modellerine (LLM\'ler) erişim sağlayan açık kaynaklı bir uygulamadır. Uygulama tüm verileri cihazınızda yerel olarak işler ve kişisel bilgileri harici sunuculara iletmez.";
"tos_user_responsibilities_title" = "3. Kullanıcı Sorumlulukları";
"tos_user_responsibilities_text" = "LLM Hub\'ı sorumlu bir şekilde ve geçerli yasalara uygun olarak kullanmayı kabul edersiniz. Sorumlusunuz:\n\n• Uygulamayı yalnızca yasal amaçlar için kullanmaktan\n• Uygulamayı tersine mühendislik yapmaya veya değiştirmeye çalışmamaktan\n• Uygulamayı zararlı, yasa dışı veya saldırgan içerik oluşturmak için kullanmamaktan\n• Üçüncü tarafların fikri mülkiyet haklarına saygı göstermekten\n• Cihazınızın düzgün çalışması için minimum gereksinimleri karşıladığından emin olmaktan";
"tos_privacy_data_title" = "4. Gizlilik ve Veriler";
"tos_privacy_data_text" = "LLM Hub gizlilik düşünülerek tasarlanmıştır:\n\n• Tüm konuşmalar ve veri işleme cihazınızda yerel olarak gerçekleşir\n• Kişisel veriler harici sunuculara iletilmez\n• Sohbet geçmişi yerel olarak saklanır ve istediğiniz zaman silinebilir\n• Model indirmeleri resmi depolardan (HuggingFace, Google) doğrudan gerçekleştirilir\n• Uygulama analitik veya kullanım verisi toplamaz";
"tos_disclaimer_title" = "5. Garanti Reddi";
"tos_disclaimer_text" = "LLM Hub herhangi bir garanti olmaksızın \"olduğu gibi\" sağlanmaktadır. Uygulamanın veya üretilen içeriğin doğruluğunu, güvenilirliğini veya kullanılabilirliğini garanti etmiyoruz. Yapay zeka modellerinin kullanımı öngörülemeyen sonuçlar üretebilir.";
"tos_limitation_liability_title" = "6. Sorumluluk Sınırlaması";
"tos_limitation_liability_text" = "LLM Hub\'ın kullanımından kaynaklanan herhangi bir dolaylı, tesadüfi, özel veya sonuç olarak ortaya çıkan zararlardan geliştiriciler hiçbir durumda sorumlu tutulamaz. Uygulamayı kullanımınız kendi riskiniz altındadır.";
"tos_model_usage_title" = "7. Model Kullanımı ve Lisanslama";
"tos_model_usage_text" = "LLM Hub aracılığıyla kullanılabilen yapay zeka modelleri kendi lisanslarına ve kullanım şartlarına tabidir. Kullanıcılar, indirilen modelleri kullanırken modele özgü lisans gereksinimlerine uymaktan sorumludur.";
"tos_open_source_title" = "8. Açık Kaynak Lisansı";
"tos_open_source_text" = "LLM Hub açık kaynaklı bir yazılımdır. Kaynak kodu, lisans şartlarına tabi olarak kullanıma, değişikliğe ve dağıtıma izin veren MIT Lisansı altında mevcuttur. Üçüncü taraf kütüphaneler ve modeller farklı lisans şartlarına sahip olabilir.";
"tos_changes_title" = "9. Şartlardaki Değişiklikler";
"tos_changes_text" = "Bu Hizmet Şartlarını zaman zaman güncelleyebiliriz. Kullanıcılar, uygulama güncellemeleri aracılığıyla önemli değişikliklerden haberdar edilecektir. Değişikliklerden sonra uygulamayı kullanmaya devam etmek, yeni şartların kabulü anlamına gelir.";
"tos_contact_title" = "10. İletişim Bilgileri";
"tos_contact_text" = "Bu Hizmet Şartları hakkında sorularınız için lütfen bizimle timmy@llm-hub.app adresinden iletişime geçin";
